-        this.amount = amount;
-        this.operation = operation;
-        this.slot = slot;
+        this.delegate = of(key, amount, operation, slot);
+    }
+
+    protected AttributeModifier() {}
+
+    /**
+     * Creates a new attribute modifier with the passed data.
+     *
+     * @param key       the unique key of the attribute modifier.
+     * @param amount    the amount the modifier applied via the operation.
+     * @param operation the operation used to apply the amount of the modifier.
+     * @param slot      the slots this attribute modifier affects.
+     * @return the newly created attribute modifier instance.
+     */
+    public static AttributeModifier of(@NotNull NamespacedKey key, double amount, @NotNull Operation operation, @NotNull EquipmentSlotGroup slot) {
+        return Bukkit.getUnsafe().attributeModifier(key, amount, operation, slot);
     }
+    // Paper end - proxy attribute modifier
 
